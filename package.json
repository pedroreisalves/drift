{
  "name": "drift",
  "version": "1.0.0",
  "private": true,
  "description": "A content platform where posts flow through discovery, get tagged by AI, and surface naturally based on engagement.",
  "workspaces": [
    "app/backend/*",
    "app/frontend"
  ],
  "scripts": {
    "test:shared": "npm run test --workspace @drift/shared",
    "test:post-service": "npm run test --workspace post-service",
    "test:tag-service": "npm run test --workspace tag-service",
    "test:search-service": "npm run test --workspace search-service",
    "coverage:shared": "npm run coverage --workspace @drift/shared",
    "coverage:post-service": "npm run coverage --workspace post-service",
    "coverage:tag-service": "npm run coverage --workspace tag-service",
    "coverage:search-service": "npm run coverage --workspace search-service"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.6.0",
    "@vitest/coverage-v8": "^4.1.5",
    "eslint": "^10.3.0",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.8.3",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.2",
    "vitest": "^4.1.5"
  }
}