{
  "compilerOptions": {
    "module": "commonjs",
    "target": "es2025",
    "strict": true,
    "skipLibCheck": true,
    "sourceMap": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "strictNullChecks": true,
    "types": ["vitest/globals", "node"]
  }
}
